# Per-branch CMS instance config for the `medicalmutual` branch.
# Copy this to `.env.medicalmutual` (gitignored) and fill in the real values.
# The `cms:push` script loads `.env.$(current branch)` automatically.

# Public site URL — used to build canonical URLs and JSON-LD pageUrl values.
# Must not have a trailing slash.
NEXT_PUBLIC_SITE_URL=

# Optimizely Graph (cms-sdk) — required for GraphClient
OPTIMIZELY_GRAPH_SINGLE_KEY=

# Optimizely CMS (cms-cli) — required for content type sync.
# The CLI routes the push to the instance these credentials belong to;
# OPTIMIZELY_CMS_URL is NOT read by the CLI (kept here only for reference).
OPTIMIZELY_CMS_URL=
OPTIMIZELY_CMS_CLIENT_ID=
OPTIMIZELY_CMS_CLIENT_SECRET=

# Opti-Admin Dashboard User and Password
OPTI_ADMIN_USER=
OPTI_ADMIN_PASSWORD=
